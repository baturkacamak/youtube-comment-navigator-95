    "prepare": "husky",
    "sync-store": "npx tsx scripts/sync-store-descriptions.ts",
    "toolkit": "node ../browser-extension-toolkit/packages/cli/dist/index.js",
    "toolkit:version": "node ../browser-extension-toolkit/packages/cli/dist/index.js version --project .",
    "toolkit:package": "node ../browser-extension-toolkit/packages/cli/dist/index.js package zip --project .",
    "toolkit:package:source": "node ../browser-extension-toolkit/packages/cli/dist/index.js package source --project .",
    "toolkit:store:descriptions": "node ../browser-extension-toolkit/packages/cli/dist/index.js store-descriptions sync --project ."
